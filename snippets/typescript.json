  "bQuery Scoped Reactivity": {
    "prefix": "bq-scoped-reactivity",
    "body": [
      "import { component, html, useSignal, useComputed, useEffect } from '@bquery/bquery/component';",
      "",
      "component('${1:scoped-counter}', {",
      "  connected() {",
      "    const ${2:count} = useSignal(${3:0});",
      "    const ${4:doubled} = useComputed(() => ${2:count}.value * 2);",
      "",
      "    useEffect(() => {",
      "      this.setState('${2:count}', ${2:count}.value);",
      "      this.setState('${4:doubled}', ${4:doubled}.value);",
      "    });",
      "  },",
      "  state: { ${2:count}: ${3:0}, ${4:doubled}: ${5:0} },",
      "  render({ state }) {",
      "    return html`<p>\\${state.${2:count}} → \\${state.${4:doubled}}</p>`;",
      "  },",
      "});"
    ],
    "description": "Create a bQuery component with scoped useSignal/useComputed/useEffect helpers"
  },
